# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000/api
VITE_AMAP_KEY=your-amap-web-js-api-key
VITE_AMAP_SECURITY_JS_CODE=your-amap-security-js-code

# Backend
APP_NAME=Building Exterior Inspection Platform
APP_ENV=development
DEBUG=true
API_PREFIX=/api
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=building_exterior
POSTGRES_USER=building_exterior
POSTGRES_PASSWORD=building_exterior_password
DATABASE_URL=postgresql+psycopg://building_exterior:building_exterior_password@localhost:5433/building_exterior

# MinIO
MINIO_API_PORT=9002
MINIO_CONSOLE_PORT=9003
MINIO_ENDPOINT=localhost:9002
MINIO_PUBLIC_URL=http://localhost:9002
MINIO_ACCESS_KEY=building_exterior_minio
MINIO_SECRET_KEY=building_exterior_minio_secret
MINIO_BUCKET=building-exterior

# Redis / RQ reserved for later algorithm jobs
REDIS_URL=redis://localhost:6379/0
RQ_DEFAULT_QUEUE=algorithm

# Algorithm worker contract
# Dev/test uses mock worker only; the real model is not deployed locally.
# In production, frontend/backend and the algorithm services run on one server.
# The worker follows the algorithm model deployment, preferably as a separate
# container from algorithm-model on a private Docker network.
WORKER_BACKEND_BASE_URL=http://localhost:8000
WORKER_ID=mock-worker-local
WORKER_TOKEN=change-this-worker-token
WORKER_MODEL_VERSION=mock-facade-detector-v1
WORKER_LEASE_SECONDS=600
WORKER_MODE=mock
ALGORITHM_INFERENCE_URL=http://algorithm-model:9002
ALGORITHM_INFERENCE_TIMEOUT_SECONDS=120

# Authentication. Change AUTH_SECRET_KEY and disable demo users in production.
AUTH_SECRET_KEY=change-this-auth-secret-key-before-production
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=480
AUTH_SEED_DEMO_USERS=true
